# 仅填写域名，不要包含 https://
DOMAIN=blog.example.com
PUBLIC_ORIGIN=https://blog.example.com

# PostgreSQL。正式部署前务必替换密码。
POSTGRES_DB=mozelle
POSTGRES_USER=mozelle
POSTGRES_PASSWORD=replace-with-a-long-random-password

# 后台密码。真实值只放在 VPS 的 .env 中，不要提交到 GitHub。
ADMIN_PASSWORD=replace-with-your-admin-password

# 可选：启用 GitHub 管理员备用登录时填写。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 可选：GitHub 备用管理员的数字账号 ID。
ADMIN_GITHUB_ID=

# 执行 openssl rand -hex 32 生成，不要提交真实值。
SESSION_SECRET=replace-with-at-least-32-random-bytes
